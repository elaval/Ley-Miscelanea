{
  "name": "ley-miscelanea-parser",
  "version": "0.3.0",
  "description": "Parser y estructurador de proyecto de ley para análisis público",
  "type": "module",
  "scripts": {
    "parse": "tsx scripts/parse-docx.ts",
    "enrich": "tsx scripts/enrich-metadata.ts",
    "link": "tsx scripts/link-descriptions.ts",
    "pipeline": "npm run parse && npm run enrich && npm run link",
    "analyze": "tsx scripts/generate-analysis.ts",
    "build": "tsc",
    "dev": "tsx --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
